<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Barbie</display-name>

    <!-- ==================== 首页 ==================== -->
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.barbie.servlet.IndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/index</url-pattern>
    </servlet-mapping>

    <!-- ==================== 搜索 ==================== -->
    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>com.barbie.servlet.SearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <!-- ==================== 用户模块 ==================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.barbie.servlet.user.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.barbie.servlet.user.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- ==================== 订单模块 ==================== -->
    <servlet>
        <servlet-name>OrderListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.OrderListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderListServlet</servlet-name>
        <url-pattern>/order/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ConfirmReceiptServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.ConfirmReceiptServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConfirmReceiptServlet</servlet-name>
        <url-pattern>/order/confirm</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OrderDetailServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.OrderDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderDetailServlet</servlet-name>
        <url-pattern>/order/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OrderCreateServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.OrderCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderCreateServlet</servlet-name>
        <url-pattern>/order/create</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>OrderDeleteServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.OrderDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderDeleteServlet</servlet-name>
        <url-pattern>/order/delete</url-pattern>
    </servlet-mapping>

    <!-- ==================== 虚拟衣橱模块 ==================== -->
    <servlet>
        <servlet-name>WardrobeListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.wardrobe.WardrobeListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardrobeListServlet</servlet-name>
        <url-pattern>/wardrobe/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>WardrobeImportServlet</servlet-name>
        <servlet-class>com.barbie.servlet.wardrobe.WardrobeImportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardrobeImportServlet</servlet-name>
        <url-pattern>/wardrobe/import</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>WardrobeDeleteServlet</servlet-name>
        <servlet-class>com.barbie.servlet.wardrobe.WardrobeDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardrobeDeleteServlet</servlet-name>
        <url-pattern>/wardrobe/delete</url-pattern>
    </servlet-mapping>

    <!-- ==================== 搭配模块 ==================== -->
    <servlet>
        <servlet-name>LookListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookListServlet</servlet-name>
        <url-pattern>/look/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookCreateServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookCreateServlet</servlet-name>
        <url-pattern>/look/create</url-pattern>
