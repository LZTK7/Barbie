        <url-pattern>/admin/user/list</url-pattern>
    </servlet-mapping>

    <!-- ==================== 默认首页 ==================== -->
    <welcome-file-list>
        <welcome-file>pages/user/login.jsp</welcome-file>
    </welcome-file-list>

</web-app>