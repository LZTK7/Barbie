        <servlet-class>com.barbie.servlet.look.LookBuyAllServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookBuyAllServlet</servlet-name>
        <url-pattern>/look/buyAll</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookGetPendingServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookGetPendingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
