        <servlet-class>com.barbie.servlet.admin.AdminProductAddServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminProductAddServlet</servlet-name>
        <url-pattern>/admin/product/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminProductEditServlet</servlet-name>
