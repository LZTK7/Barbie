        <url-pattern>/look/getPendingProducts</url-pattern>
    </servlet-mapping>

    <!-- ==================== 购物车模块 ==================== -->
    <servlet>
        <servlet-name>CartListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.cart.CartListServlet</servlet-class>
