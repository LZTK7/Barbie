<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Barbie</display-name>

    <!-- ==================== 首页 ==================== -->
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.barbie.servlet.IndexServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/index</url-pattern>
    </servlet-mapping>

    <!-- ==================== 用户模块 ==================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.barbie.servlet.user.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- ==================== 订单模块 ==================== -->
    <servlet>
        <servlet-name>OrderListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.OrderListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderListServlet</servlet-name>
        <url-pattern>/order/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ConfirmReceiptServlet</servlet-name>
        <servlet-class>com.barbie.servlet.order.ConfirmReceiptServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ConfirmReceiptServlet</servlet-name>
        <url-pattern>/order/confirm</url-pattern>
    </servlet-mapping>

    <!-- ==================== 虚拟衣橱模块 ==================== -->
    <servlet>
        <servlet-name>WardrobeListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.wardrobe.WardrobeListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardrobeListServlet</servlet-name>
        <url-pattern>/wardrobe/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>WardrobeImportServlet</servlet-name>
        <servlet-class>com.barbie.servlet.wardrobe.WardrobeImportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardrobeImportServlet</servlet-name>
        <url-pattern>/wardrobe/import</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>WardrobeDeleteServlet</servlet-name>
        <servlet-class>com.barbie.servlet.wardrobe.WardrobeDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WardrobeDeleteServlet</servlet-name>
        <url-pattern>/wardrobe/delete</url-pattern>
    </servlet-mapping>

    <!-- ==================== 搭配模块 ==================== -->
    <servlet>
        <servlet-name>LookListServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookListServlet</servlet-name>
        <url-pattern>/look/list</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookCreateServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookCreateServlet</servlet-name>
        <url-pattern>/look/create</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookDeleteServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookDeleteServlet</servlet-name>
        <url-pattern>/look/delete</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookDetailServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookDetailServlet</servlet-name>
        <url-pattern>/look/detail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookEditServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookEditServlet</servlet-name>
        <url-pattern>/look/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookSearchServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookSearchServlet</servlet-name>
        <url-pattern>/look/search</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookAddPendingServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookAddPendingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookAddPendingServlet</servlet-name>
        <url-pattern>/look/addPending</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookRemovePendingServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookRemovePendingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookRemovePendingServlet</servlet-name>
        <url-pattern>/look/removePending</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LookBuyAllServlet</servlet-name>
        <servlet-class>com.barbie.servlet.look.LookBuyAllServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LookBuyAllServlet</servlet-name>
        <url-pattern>/look/buyAll</url-pattern>
    </servlet-mapping>

    <!-- ==================== 默认首页 ==================== -->
    <welcome-file-list>
        <welcome-file>pages/index.jsp</welcome-file>
    </welcome-file-list>

</web-app>